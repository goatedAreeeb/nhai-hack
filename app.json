{
  "expo": {
    "name": "DatalakeOfflineAuth",
    "slug": "NHAIHackathon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nhaihackathon",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.anonymous.NHAIHackathon",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.NHAIHackathon",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera required for face recognition and liveness detection",
        "NSLocationWhenInUseUsageDescription": "Location required for GPS geofence verification",
        "NSLocationAlwaysUsageDescription": "Location required for GPS geofence verification"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "react-native-fast-tflite",
      "onnxruntime-react-native",
      "expo-asset"
    ]
  }
}
